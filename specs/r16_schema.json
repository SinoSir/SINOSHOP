{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SINOSHOP R16 Encoded Component",
  "description": "JSON Schema for the SINOR Encoded Component, compatible with the Protobuf definition.",
  "type": "object",
  "required": ["org", "seg", "type", "instance_id", "firmware_version"],
  "properties": {
    "org": {
      "type": "string",
      "pattern": "^[A-Z0-9]{3,8}$",
      "description": "Organization code, 3-8 uppercase alphanumeric characters."
    },
    "seg": {
      "type": "string",
      "description": "Segment identifier, e.g. 'SFT-01'."
    },
    "zon": {
      "type": "string",
      "description": "Zone identifier within the segment."
    },
    "type": {
      "type": "string",
      "enum": ["SENSOR", "ACTUATOR", "CONTROLLER", "COMMUNICATION", "POWER", "STRUCTURE", "SAFETY", "OTHER"],
      "description": "Component type."
    },
    "instance_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Unique instance number within the type."
    },
    "firmware_version": {
      "type": "string",
      "description": "Firmware signature version, e.g. '3.0.0'."
    },
    "integrity_hash": {
      "type": "string",
      "description": "Base64 encoded integrity hash."
    },
    "ext_attributes": {
      "type": "object",
      "description": "Optional extended attributes."
    }
  }
}
